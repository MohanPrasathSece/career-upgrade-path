{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "routes": [
    { "src": "/api/admin/login", "dest": "/api/admin/login.ts" },
    { "src": "/api/admin/(.*)", "dest": "/api/admin/[...slug].ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
